# Files and directories excluded from the distributable plugin zip.
# Consumed by `wp-scripts plugin-zip` (npm run plugin-zip).
# Everything not listed here ships in the zip.

# VCS and CI
.git
.github
.gitignore

# Agent / editor tooling
.claude
.hyper
.vscode
AGENTS.md
CLAUDE.md
.editorconfig

# Dependencies (no runtime Composer/npm deps; PSR-4 autoloader is in the plugin)
node_modules
vendor

# Build / dev config
.npmrc
.nvmrc
.prettierignore
.prettierrc.js
.phpcs.xml.dist
phpstan.neon.dist
phpunit.xml.dist
package.json
package-lock.json
composer.json
composer.lock
.wp-env.json
.wp-env.test.json

# Tests and internal docs (build plan, not end-user docs)
tests
docs

# OS cruft
.DS_Store
Thumbs.db
*.log
