# https://phpstan.org/config-reference

parameters:
	# Rules
	treatPhpDocTypesAsCertain: false
	inferPrivatePropertyTypeFromConstructor: true
	checkExplicitMixedMissingReturn: true
	checkFunctionNameCase: true
	checkInternalClassCaseSensitivity: true
	checkTooWideReturnTypesInProtectedAndPublicMethods: true
	polluteScopeWithAlwaysIterableForeach: false
	polluteScopeWithLoopInitialAssignments: false
	reportAlwaysTrueInLastCondition: true
	reportStaticMethodSignatures: true
	reportWrongPhpDocTypeInVarTag: true

	# Configuration
	level: 8
	phpVersion:
		min: 80100
		max: 80500
	bootstrapFiles:
		- abilities-catalog.php
	paths:
		- abilities-catalog.php
		- includes/
	excludePaths:
		analyse:
			- vendor/
		analyseAndScan:
			- node_modules (?)

	# Do not fail when an ignore pattern matches nothing (keeps the shared
	# ignore list portable as the codebase changes).
	reportUnmatchedIgnoredErrors: false

	ignoreErrors:
		- # TODO: These are too noisy, we'll restore them in the future.
			identifier: missingType.iterableValue

		# `wp_get_connector()`, `wp_get_connectors()`, and
		# `wp_is_connector_registered()` are WP 7.0 core Connectors API functions.
		# They exist at runtime (verified in wp-env WP 7.0: connectors.php:23, 85, 150)
		# but are absent from php-stubs/wordpress-stubs ^6.9, so PHPStan cannot see them.
		-
			identifier: function.notFound
			message: '#Function (wp_get_connectors?|wp_is_connector_registered) not found\.#'
			path: includes/Abilities/Core/Connectors

		# export_wp() stubs type $args['author'] and $args['category'] as string, but
		# the catalog passes integer IDs. export_wp() resolves the category via
		# term_exists( $args['category'], 'category' ), which needs the term ID (a
		# numeric string is looked up as a slug instead), and the author via a %d
		# prepared statement. Integers are correct at runtime; the stub is too narrow.
		-
			identifier: argument.type
			path: includes/Abilities/Core/Tools/ExportContent.php

		# McpAdapter::create_server() is phpdoc'd `list<string> $tools`, but it also
		# accepts hand-built McpTool instances (McpComponentRegistry::register_single_tool
		# case 0; verified by source and a live wp-env smoke test, spec §5). The server
		# registers curated domain McpTool instances, so the vendor phpdoc is too narrow.
		-
			identifier: argument.type
			message: '#Parameter \#10 \$tools of method WP\\MCP\\Core\\McpAdapter::create_server\(\) expects list<string>, list<WP\\MCP\\Domain\\Tools\\McpTool> given\.#'
			paths:
				- includes/Mcp/Server.php
				- includes/Mcp/SearchServer.php
