.DS_Store
Thumbs.db
*.log
/vendor/
/node_modules/

# Distributable plugin zip built by `npm run plugin-zip` (and by the release CI).
/abilities-catalog.zip

# Local wp-env config (machine-specific plugin paths)
/.wp-env.json
/.wp-env.override.json

# Local MCP client config — holds an Application Password; never commit.
# Pattern covers stray duplicates too (e.g. ".mcp copy.json").
/.mcp.json
.mcp*.json

# Test output (keep the directory, ignore generated reports/caches)
/tests/_output/*
!/tests/_output/.gitkeep

# composer.lock IS committed: the plugin now has runtime deps (mcp-adapter,
# jetpack-autoloader), and the CI release build runs `composer install --no-dev`.
